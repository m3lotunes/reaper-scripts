+-- Action 43345 = "Markers: Set project time offset to current edit cursor
+-- position" — the same action that Reaper's ruler-right-click menu runs
+-- under "Change start time/measure → Set 0:00 to current edit cursor".
+-- Using the built-in action is version-proof and doesn't need the project
+-- state chunk API (which is missing on some Reaper builds).
+local ACTION_SET_TIMEOFFS_TO_CURSOR = 43345
+
 -- Shift the project ruler so that the edit-cursor position becomes 0:00 AND
